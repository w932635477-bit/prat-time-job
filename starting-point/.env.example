# DeepSeek / LLM
SP_DEEPSEEK_API_KEY=your-evolink-api-key-here
SP_DEEPSEEK_BASE_URL=https://direct.evolink.ai
SP_DEEPSEEK_MODEL=deepseek-v4-flash
SP_DEEPSEEK_THINKING=true

# Database
SP_DATABASE_PATH=/app/data/starting_point.db

# JWT (min 16 characters)
SP_JWT_SECRET=your-jwt-secret-at-least-32-chars

# CORS — comma-separated origins for production
# Development default: http://127.0.0.1:8000,http://localhost:8000
SP_CORS_ORIGINS=https://firesing.cn,https://www.firesing.cn

# WeChat Login
SP_WX_APP_ID=your-wechat-app-id
SP_WX_APP_SECRET=your-wechat-app-secret

# WeChat Pay
SP_WX_PAY_MCH_ID=your-merchant-id
SP_WX_PAY_API_KEY=your-pay-api-key-32-chars

# Admin (min 8 characters)
SP_ADMIN_PASSWORD=your-admin-password

# FireCrawl
SP_FIRECRAWL_API_KEY=your-firecrawl-api-key
